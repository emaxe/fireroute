generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BlockedEndpoint {
  id        String   @id @default(uuid())
  pattern   String   @unique
  message   String   @default("Endpoint not supported")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("blocked_endpoints")
}

model Model {
  id        String   @id @default(uuid())
  modelId   String   @unique @map("model_id")
  name      String?
  type      String   @default("chat")
  active    Boolean  @default(true)
  source    String   @default("upstream")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("models")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model ServiceToken {
  id        String   @id @default(uuid())
  token     String   @unique
  name      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")

  groups TokenGroup[]
  logs   RequestLog[]

  @@map("service_tokens")
}

model ApiKey {
  id        String   @id @default(uuid())
  name      String
  key       String
  active    Boolean  @default(true)
  suspended Boolean  @default(false)
  lastUsed  DateTime? @map("last_used")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  groups GroupMember[]
  logs   RequestLog[]

  @@map("api_keys")
}

model KeyGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members      GroupMember[]
  tokenGroups  TokenGroup[]
  currentIndex Int           @default(0) @map("current_index")

  @@map("key_groups")
}

model GroupMember {
  id      String @id @default(uuid())
  groupId String @map("group_id")
  keyId   String @map("key_id")

  group KeyGroup @relation(fields: [groupId], references: [id])
  key   ApiKey   @relation(fields: [keyId], references: [id])

  @@unique([groupId, keyId])
  @@map("group_members")
}

model TokenGroup {
  id      String @id @default(uuid())
  tokenId String @map("token_id")
  groupId String @map("group_id")

  token ServiceToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  group KeyGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([tokenId, groupId])
  @@map("token_groups")
}

model RequestLog {
  id        String   @id @default(uuid())
  tokenId   String?  @map("token_id")
  keyId     String?  @map("key_id")
  groupId   String?  @map("group_id")
  endpoint  String
  status    Int
  latencyMs Int      @map("latency_ms")
  promptTokens     Int? @map("prompt_tokens")
  completionTokens Int? @map("completion_tokens")
  totalTokens      Int? @map("total_tokens")
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  token ServiceToken? @relation(fields: [tokenId], references: [id])
  key   ApiKey?       @relation(fields: [keyId], references: [id])

  @@map("request_logs")
}
